type metadataRequest struct {
	DocID string `json:"docid"`
}

type metadataResponse struct {
	DocID  string `json:"docid"`
	Name   string `json:"name"`
	Size   int64  `json:"size,omitempty"`
	Rev    string `json:"rev"`
	Modified int64 `json:"modified"`
}

func (p *Provider) Stat(ctx context.Context, remotePath string) (domain.FileInfo, error) {
	return domain.FileInfo{}, fmt.Errorf("huadian Stat(%q): %w", remotePath, ErrNotImplemented)
}

// StatByDocID returns metadata for a single file by docid.
func (p *Provider) StatByDocID(ctx context.Context, docID string) (domain.FileInfo, error) {
	var resp metadataResponse
	if err := p.post(ctx, "/api/efast/v1/file/metadata", metadataRequest{DocID: docID}, &resp); err != nil {
		return domain.FileInfo{}, err
	}
	return domain.FileInfo{
		Path:    "/" + resp.Name,
		Size:    resp.Size,
		ModTime: time.UnixMicro(resp.Modified),
		ETag:    resp.Rev,
	}, nil
}

