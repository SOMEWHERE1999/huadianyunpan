// Package huadian implements the cloud.Provider interface for the
// Huadian AnyShare cloud storage service.
//
// All HTTP endpoints are confirmed via browser HAR capture.
// Unconfirmed interfaces return ErrNotImplemented.
// Security: no passwords, tokens, or cookies are logged or stored in plaintext.
package huadian

import (
	"bytes"
	"context"
	"crypto/md5"
	"encoding/json"
	"errors"
	"fmt"
	"io"
	"net/http"
	"strconv"
	"strings"
	"time"

	"ncepupan/hdd/internal/cloud"
	"ncepupan/hdd/internal/domain"
)

// Compile-time check.
var _ cloud.Provider = (*Provider)(nil)

// Sentinel errors.
var (
	ErrNotImplemented           = errors.New("huadian: not implemented")
	ErrInteractiveLoginRequired = errors.New("huadian: interactive login required; obtain tokens via browser")
	ErrUnauthorized             = errors.New("huadian: unauthorized")
	ErrNotFound                 = errors.New("huadian: not found")
)

const (
	baseURL        = "https://pan.ncepu.edu.cn"
	defaultTimeout = 30 * time.Second
)

// Provider implements cloud.Provider for Huadian AnyShare.
type Provider struct {
	baseURL     string
	accessToken string
	client      *http.Client
}

// New creates a Provider.  accessToken may be empty (caller must supply
// a valid token before making API calls), in which case Connect will
// return ErrUnauthorized.
func New(accessToken string) *Provider {
	return &Provider{
		baseURL:     baseURL,
		accessToken: accessToken,
		client: &http.Client{
			Timeout: defaultTimeout,
		},
	}
}

func (p *Provider) Name() string { return "huadian" }

// ---------------------------------------------------------------------------
// Authentication
// ---------------------------------------------------------------------------

func (p *Provider) Connect(_ context.Context) error {
	if p.accessToken == "" {
		return ErrInteractiveLoginRequired
	}
	return nil
}

func (p *Provider) Disconnect(_ context.Context) error { return nil }

// Login is not implemented.  Use the browser to obtain tokens.
func (p *Provider) Login(ctx context.Context) error {
	return ErrInteractiveLoginRequired
}

// ---------------------------------------------------------------------------
// Internal helpers
// ---------------------------------------------------------------------------

func (p *Provider) post(ctx context.Context, path string, body any, result any) error {
	url := p.baseURL + path

	var reqBody io.Reader
	if body != nil {
		data, err := json.Marshal(body)
		if err != nil {
			return fmt.Errorf("marshal: %w", err)
		}
		reqBody = bytes.NewReader(data)
	}

	req, err := http.NewRequestWithContext(ctx, "POST", url, reqBody)
	if err != nil {
		return fmt.Errorf("new request: %w", err)
	}
	req.Header.Set("Content-Type", "application/json")
	if p.accessToken != "" {
		req.Header.Set("Authorization", "Bearer "+p.accessToken)
	}

	resp, err := p.client.Do(req)
	if err != nil {
		return fmt.Errorf("http: %w", err)
	}
	defer resp.Body.Close()

	if resp.StatusCode == 401 {
		return ErrUnauthorized
	}
	if resp.StatusCode == 404 {
		return ErrNotFound
	}
	if resp.StatusCode >= 400 {
		body, _ := io.ReadAll(io.LimitReader(resp.Body, 4096))
		return fmt.Errorf("huadian: %d: %s", resp.StatusCode, strings.TrimSpace(string(body)))
	}

	if result != nil {
		if err := json.NewDecoder(resp.Body).Decode(result); err != nil {
			return fmt.Errorf("decode: %w", err)
		}
	}
	return nil
}

// ---------------------------------------------------------------------------
// List
// ---------------------------------------------------------------------------

type dirListRequest struct {
	DocID  string `json:"docid"`
	ListBy string `json:"listby,omitempty"`
	SortBy string `json:"sortby,omitempty"`
	Reverse bool  `json:"reverse,omitempty"`
	Count   int   `json:"count,omitempty"`
}

type dirListResponse struct {
	Files []fileEntry `json:"files"`
}

type fileEntry struct {
	DocID      string `json:"docid"`
	Name       string `json:"name"`
	Size       int64  `json:"size,omitempty"`
	Rev        string `json:"rev"`
	Modified   int64  `json:"modified"`   // microseconds
	Editor     string `json:"editor"`
	IsDir      bool   `json:"isdir"`
}

func (p *Provider) List(ctx context.Context, remotePath string) ([]domain.FileInfo, error) {
	// The documented endpoint uses docid, not path.  Until path‑to‑docid
	// lookup is confirmed, return ErrNotImplemented.
	_ = remotePath
	return nil, fmt.Errorf("huadian List(%q): %w", remotePath, ErrNotImplemented)
}

// ListByDocID performs a directory listing using a docid.
func (p *Provider) ListByDocID(ctx context.Context, docID string) ([]domain.FileInfo, error) {
	var resp dirListResponse
	req := dirListRequest{DocID: docID, Count: 100}
	if err := p.post(ctx, "/api/efast/v1/dir/list", req, &resp); err != nil {
		return nil, err
	}
	var out []domain.FileInfo
	for _, e := range resp.Files {
		out = append(out, domain.FileInfo{
			Path:    "/" + e.Name,
			Size:    e.Size,
			ModTime: time.UnixMicro(e.Modified),
			IsDir:   e.IsDir,
			ETag:    e.Rev,
		})
	}
	return out, nil
}

