type predupRequest struct {
	SliceMD5 string `json:"slice_md5"`
	Length   int64  `json:"length"`
}

type predupResponse struct {
	Match bool `json:"match"`
}

type osBeginUploadRequest struct {
	DocID     string `json:"docid"`
	Name      string `json:"name"`
	Length    int64  `json:"length"`
	OnDup     int    `json:"ondup,omitempty"`
}

type osBeginUploadResponse struct {
	AuthRequest json.RawMessage `json:"authrequest"`
	DocID       string          `json:"docid"`
	Rev         string          `json:"rev"`
	Name        string          `json:"name"`
}

type osEndUploadRequest struct {
	DocID string `json:"docid"`
	Rev   string `json:"rev"`
}

func (p *Provider) Upload(ctx context.Context, remotePath string, r io.Reader) error {
	return fmt.Errorf("huadian Upload(%q): %w", remotePath, ErrNotImplemented)
}

// UploadByDocID performs the full AnyShare upload flow.
func (p *Provider) UploadByDocID(ctx context.Context, parentDocID, name string, r io.Reader, size int64) error {
	// Read content for MD5.
	data, err := io.ReadAll(io.LimitReader(r, size+1))
	if err != nil {
		return fmt.Errorf("read upload: %w", err)
	}
	if int64(len(data)) != size {
		return fmt.Errorf("size mismatch: got %d, want %d", len(data), size)
	}

	// Step 1: predupload (MD5 check).
	md5Sum := fmt.Sprintf("%x", md5.Sum(data))
	var predup predupResponse
	if err := p.post(ctx, "/api/efast/v1/file/predupload", predupRequest{
		SliceMD5: md5Sum,
		Length:   size,
	}, &predup); err != nil {
		return fmt.Errorf("predupload: %w", err)
	}
	// If match==true, the file already exists — treat as success.
	if predup.Match {
		return nil
	}

	// Step 2: osbeginupload.
	var begin osBeginUploadResponse
	if err := p.post(ctx, "/api/efast/v1/file/osbeginupload", osBeginUploadRequest{
		DocID:  parentDocID,
		Name:   name,
		Length: size,
	}, &begin); err != nil {
		return fmt.Errorf("osbeginupload: %w", err)
	}

	// Step 3: upload to object storage.
	// authrequest contains the upload URL, policy, signature etc.
	var ar authRequest
	if err := json.Unmarshal(begin.AuthRequest, &ar); err != nil {
		return fmt.Errorf("parse authrequest: %w", err)
	}
	if err := p.uploadToStorage(ctx, &ar, data); err != nil {
		return fmt.Errorf("storage upload: %w", err)
	}

	// Step 4: osendupload.
	if err := p.post(ctx, "/api/efast/v1/file/osendupload", osEndUploadRequest{
		DocID: begin.DocID,
		Rev:   begin.Rev,
	}, nil); err != nil {
		return fmt.Errorf("osendupload: %w", err)
	}

	return nil
}

type authRequest struct {
	Method    string `json:"method"`
	URL       string `json:"url"`
	Policy    string `json:"policy,omitempty"`
	Signature string `json:"signature,omitempty"`
	Key       string `json:"key,omitempty"`
}

func (p *Provider) uploadToStorage(ctx context.Context, ar *authRequest, data []byte) error {
	req, err := http.NewRequestWithContext(ctx, ar.Method, ar.URL, bytes.NewReader(data))
	if err != nil {
		return err
	}
	req.Header.Set("Content-Type", "application/octet-stream")
	resp, err := p.client.Do(req)
	if err != nil {
		return err
	}
	defer resp.Body.Close()
	if resp.StatusCode >= 400 {
		body, _ := io.ReadAll(io.LimitReader(resp.Body, 4096))
		return fmt.Errorf("storage upload %d: %s", resp.StatusCode, strings.TrimSpace(string(body)))
	}
	return nil
}

// ---------------------------------------------------------------------------
// Download
// ---------------------------------------------------------------------------

type osDownloadRequest struct {
	DocID string `json:"docid"`
}

type osDownloadResponse struct {
	AuthRequest json.RawMessage `json:"authrequest"`
}

func (p *Provider) Download(ctx context.Context, remotePath string, w io.Writer) error {
	return fmt.Errorf("huadian Download(%q): %w", remotePath, ErrNotImplemented)
}

// DownloadByDocID performs the AnyShare download flow.
func (p *Provider) DownloadByDocID(ctx context.Context, docID string, w io.Writer) error {
	var dl osDownloadResponse
	if err := p.post(ctx, "/api/efast/v1/file/osdownload", osDownloadRequest{
		DocID: docID,
	}, &dl); err != nil {
		return fmt.Errorf("osdownload: %w", err)
	}

	var ar authRequest
	if err := json.Unmarshal(dl.AuthRequest, &ar); err != nil {
		return fmt.Errorf("parse authrequest: %w", err)
	}

	req, err := http.NewRequestWithContext(ctx, ar.Method, ar.URL, nil)
	if err != nil {
		return err
	}
	resp, err := p.client.Do(req)
	if err != nil {
		return err
	}
	defer resp.Body.Close()
	if resp.StatusCode >= 400 {
		body, _ := io.ReadAll(io.LimitReader(resp.Body, 4096))
		return fmt.Errorf("storage download %d: %s", resp.StatusCode, strings.TrimSpace(string(body)))
	}

	_, err = io.Copy(w, resp.Body)
	return err
}

