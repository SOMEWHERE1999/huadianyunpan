func (p *Provider) downloadFromStorage(ctx context.Context, ar *authRequest, w io.Writer) error {
	req, err := http.NewRequestWithContext(ctx, ar.Method, ar.URL, nil)
	if err != nil {
		return errors.New("invalid object storage request")
	}
	setBrowserHeaders(req)
	// Auth headers override browser Date to avoid AWS signature mismatch.
	req.Header.Del("Date")
	for k, v := range ar.Headers {
		req.Header.Set(k, v)
	}
	resp, err := (&http.Client{Timeout: defaultTimeout}).Do(req)
	if err != nil {
		securelog.LogSecurityEvent(ctx, securelog.SecurityEvent{Operation: "storage_download", Method: ar.Method, Path: "<signed>", ErrorClass: "network"})
		return errors.New("object storage request failed")
	}
	defer resp.Body.Close()
	if resp.StatusCode >= 400 {
		securelog.LogSecurityEvent(ctx, securelog.SecurityEvent{Operation: "storage_download", Method: ar.Method, Path: "<signed>", Status: resp.StatusCode, RequestID: resp.Header.Get("X-Request-ID"), ErrorClass: "remote_error"})
		return fmt.Errorf("storage download: remote status %d", resp.StatusCode)
	}

	_, err = io.Copy(w, resp.Body)
	return err
}

