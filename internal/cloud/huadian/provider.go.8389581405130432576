func (p *Provider) Upload(ctx context.Context, remotePath string, r io.Reader) error {
	parentDir, name := dirAndName(remotePath)
	docID, err := p.resolvePath(ctx, parentDir)
	if err != nil {
		return fmt.Errorf("huadian Upload(%q): %w", remotePath, err)
	}
	tmp, err := os.CreateTemp("", "hdd-upload-*")
	if err != nil {
		return fmt.Errorf("create upload spool: %w", err)
	}
	defer func() { _ = tmp.Close(); _ = os.Remove(tmp.Name()) }()
	size, err := io.Copy(tmp, r)
	if err != nil {
		return fmt.Errorf("spool upload: %w", err)
	}
	if _, err := tmp.Seek(0, io.SeekStart); err != nil {
		return fmt.Errorf("rewind upload spool: %w", err)
	}
	if _, err := p.uploadSeekable(ctx, docID, name, tmp, size, time.Now(), cloud.UploadConflictFail); err != nil {
		return err
	}
	// Invalidate parent so subsequent List returns fresh data.
	p.invalidateCache(parentDir)
	return nil
}

// UploadByDocID performs the full AnyShare upload flow.
func (p *Provider) UploadByDocID(ctx context.Context, parentDocID, name string, r io.Reader, size int64) error {
	// Step 1: predupload (MD5 check) — compute MD5 streaming.
	tmp, err := os.CreateTemp("", "hdd-upload-*")
	if err != nil {
		return fmt.Errorf("create upload spool: %w", err)
	}
	defer func() { _ = tmp.Close(); _ = os.Remove(tmp.Name()) }()
	written, err := io.Copy(tmp, io.LimitReader(r, size+1))
	if err != nil {
		return fmt.Errorf("spool upload: %w", err)
	}
	if written != size {
		return fmt.Errorf("size mismatch: got %d, want %d", written, size)
	}
	if _, err := tmp.Seek(0, io.SeekStart); err != nil {
		return fmt.Errorf("rewind upload spool: %w", err)
	}
	_, err = p.uploadSeekable(ctx, parentDocID, name, tmp, size, time.Now(), cloud.UploadConflictFail)
	return err
}

type authRequest struct {
	Method    string            `json:"method"`
	URL       string            `json:"url"`
	Policy    string            `json:"policy,omitempty"`
	Signature string            `json:"signature,omitempty"`
	Key       string            `json:"key,omitempty"`
	Headers   map[string]string `json:"-"`
	Fields    []authField       `json:"-"`
}

type authField struct {
	Name  string
	Value string
}

// parseAuthRequest handles object, string-array, and object-array forms.
func parseAuthRequest(raw json.RawMessage) (*authRequest, error) {
	if len(raw) == 0 {
		return nil, fmt.Errorf("empty authrequest")
	}
	// 1. Object form (upload): {"method":"PUT","url":"https://...",...}
	var ar authRequest
	if err := json.Unmarshal(raw, &ar); err == nil && ar.URL != "" {
		return &ar, nil
	}
	// 2. String array form (download): ["GET","https://...","Authorization: AWS ...","x-amz-date: ..."]
	var arr []string
	if err := json.Unmarshal(raw, &arr); err == nil && len(arr) >= 2 {
		ar := &authRequest{Method: arr[0], URL: arr[1]}
		if len(arr) > 2 {
			ar.Headers = make(map[string]string)
			for _, h := range arr[2:] {
				if idx := strings.IndexByte(h, ':'); idx > 0 {
					ar.Headers[strings.TrimSpace(h[:idx])] = strings.TrimSpace(h[idx+1:])
				}
			}
		}
		return ar, nil
	}
	// 3. Object array form (compat): [{"method":"PUT",...}]
	var ars []authRequest
	if err := json.Unmarshal(raw, &ars); err == nil && len(ars) > 0 {
		return &ars[0], nil
	}
	return nil, fmt.Errorf("authrequest: unsupported format")
}

func parseUploadAuthRequest(raw json.RawMessage) (*authRequest, error) {
	var values []string
	if err := json.Unmarshal(raw, &values); err != nil || len(values) < 2 {
		return nil, errors.New("upload authrequest: malformed array")
	}
	if !strings.EqualFold(values[0], http.MethodPost) {
		return nil, errors.New("upload authrequest: unsupported method")
	}
	parsedURL, err := url.Parse(values[1])
	if err != nil || parsedURL.Host == "" || (parsedURL.Scheme != "https" && parsedURL.Scheme != "http") {
		return nil, errors.New("upload authrequest: invalid URL")
	}
	ar := &authRequest{Method: http.MethodPost, URL: values[1]}
	required := map[string]bool{
		"AWSAccessKeyId": false,
		"Content-Type":   false,
		"Policy":         false,
		"Signature":      false,
		"key":            false,
	}
	for _, line := range values[2:] {
		name, value, ok := strings.Cut(line, ":")
		name = strings.TrimSpace(name)
		if !ok || name == "" {
			return nil, errors.New("upload authrequest: malformed field")
		}
		if strings.HasPrefix(value, " ") {
			value = value[1:]
		}
		ar.Fields = append(ar.Fields, authField{Name: name, Value: value})
		if _, ok := required[name]; ok {
			required[name] = true
		}
	}
	for _, name := range []string{"AWSAccessKeyId", "Content-Type", "Policy", "Signature", "key"} {
		if !required[name] {
			return nil, fmt.Errorf("upload authrequest: missing field %s", name)
		}
	}
	return ar, nil
}

func buildMultipartUpload(ar *authRequest, file io.Reader, fileSize int64, filename string) (io.Reader, string, int64, error) {
	var preamble bytes.Buffer
	w := multipart.NewWriter(&preamble)
	for _, field := range ar.Fields {
		if err := w.WriteField(field.Name, field.Value); err != nil {
			return nil, "", 0, err
		}
	}
	header := make(textproto.MIMEHeader)
	header.Set("Content-Disposition", fmt.Sprintf(`form-data; name="file"; filename="%s"`, strings.ReplaceAll(filepath.Base(filename), `"`, `\"`)))
	header.Set("Content-Type", "application/octet-stream")
	if _, err := w.CreatePart(header); err != nil {
		return nil, "", 0, err
	}

	var epilogue bytes.Buffer
	closing := multipart.NewWriter(&epilogue)
	if err := closing.SetBoundary(w.Boundary()); err != nil {
		return nil, "", 0, err
	}
	if err := closing.Close(); err != nil {
		return nil, "", 0, err
	}
	length := int64(preamble.Len()) + fileSize + int64(epilogue.Len())
	return io.MultiReader(bytes.NewReader(preamble.Bytes()), file, bytes.NewReader(epilogue.Bytes())), w.FormDataContentType(), length, nil
}

func (p *Provider) uploadToStorage(ctx context.Context, ar *authRequest, file io.Reader, fileSize int64, filename string) error {
	body, contentType, contentLength, err := buildMultipartUpload(ar, file, fileSize, filename)
	if err != nil {
		return errors.New("invalid object storage multipart request")
	}
	req, err := http.NewRequestWithContext(ctx, http.MethodPost, ar.URL, body)
	if err != nil {
		return errors.New("invalid object storage request")
	}
	req.Header.Set("Content-Type", contentType)
	req.ContentLength = contentLength
	storageClient := &http.Client{
		Timeout: defaultTimeout,
		CheckRedirect: func(_ *http.Request, _ []*http.Request) error {
			return errors.New("object storage redirect refused")
		},
	}
	resp, err := storageClient.Do(req)
	if err != nil {
		securelog.LogSecurityEvent(ctx, securelog.SecurityEvent{Operation: "storage_upload", Method: ar.Method, Path: "<signed>", ErrorClass: "network"})
		return errors.New("object storage request failed")
	}
	defer resp.Body.Close()
	if resp.StatusCode != http.StatusNoContent {
		code := storageErrorCode(resp.Body)
		securelog.LogSecurityEvent(ctx, securelog.SecurityEvent{Operation: "storage_upload", Method: ar.Method, Path: "<signed>", Status: resp.StatusCode, RequestID: resp.Header.Get("X-Request-ID"), ErrorClass: "remote_error"})
		if code != "" {
			return fmt.Errorf("storage upload: status=%d code=%s", resp.StatusCode, code)
		}
		return fmt.Errorf("storage upload: status=%d", resp.StatusCode)
	}
	return nil
}

func storageErrorCode(r io.Reader) string {
	raw, _ := io.ReadAll(io.LimitReader(r, 64<<10))
	start := bytes.Index(raw, []byte("<Code>"))
	end := bytes.Index(raw, []byte("</Code>"))
	if start < 0 || end <= start+len("<Code>") {
		return ""
	}
	code := string(raw[start+len("<Code>") : end])
	for _, ch := range code {
		if !((ch >= 'a' && ch <= 'z') || (ch >= 'A' && ch <= 'Z') || (ch >= '0' && ch <= '9') || ch == '_' || ch == '-' || ch == '.') {
			return ""
		}
	}
	return code
}

