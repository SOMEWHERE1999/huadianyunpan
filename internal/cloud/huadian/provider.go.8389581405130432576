// setBrowserHeaders sets WAF-bypass headers on the request to mimic
// a real Edge/Chrome browser. The CDN/WAF at pan.ncepu.edu.cn and
// its storage servers reject requests without these.
func setBrowserHeaders(req *http.Request) {
	req.Header.Set("User-Agent", "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/149.0.0.0 Safari/537.36 Edg/149.0.0.0")
	req.Header.Set("sec-ch-ua", `"Microsoft Edge";v="149", "Chromium";v="149", "Not)A;Brand";v="24"`)
	req.Header.Set("sec-ch-ua-mobile", "?0")
	req.Header.Set("sec-ch-ua-platform", `"Windows"`)
	req.Header.Set("Date", time.Now().UTC().Format(time.RFC1123))
}

func (p *Provider) post(ctx context.Context, apiPath string, body any, result any) error {
	url := p.baseURL + apiPath

	var reqBody io.Reader
	if body != nil {
		data, err := json.Marshal(body)
		if err != nil {
			return fmt.Errorf("marshal: %w", err)
		}
		reqBody = bytes.NewReader(data)
	}

	req, err := http.NewRequestWithContext(ctx, "POST", url, reqBody)
	if err != nil {
		return fmt.Errorf("new request: %w", err)
	}
	req.Header.Set("Content-Type", "application/json")
	req.Header.Set("Accept", "application/json, text/plain, */*")
	req.Header.Set("Accept-Language", "zh-CN,zh;q=0.9")
	setBrowserHeaders(req)
	req.Header.Set("X-Language", "zh-CN")
	req.Header.Set("Referer", p.baseURL+"/anyshare/")
	req.Header.Set("Origin", p.baseURL)
	req.Header.Set("X-Requested-With", "XMLHttpRequest")
	req.Header.Set("Sec-Fetch-Site", "same-origin")
	req.Header.Set("Sec-Fetch-Mode", "cors")
	req.Header.Set("Sec-Fetch-Dest", "empty")
	if p.csrfToken != "" {
		req.Header.Set("X-CSRF-TOKEN", p.csrfToken)
	}
	if p.accessToken != "" && p.useToken {
		req.Header.Set("Authorization", "Bearer "+p.accessToken)
	}

	resp, err := p.client.Do(req)
	if err != nil {
		securelog.LogSecurityEvent(ctx, securelog.SecurityEvent{Operation: "api_request", Method: req.Method, Path: apiPath, ErrorClass: "network"})
		return fmt.Errorf("http: %w", err)
	}
	defer resp.Body.Close()
	requestID := resp.Header.Get("X-Request-ID")

	if resp.StatusCode == 401 {
		securelog.LogSecurityEvent(ctx, securelog.SecurityEvent{Operation: "api_request", Method: req.Method, Path: apiPath, Status: resp.StatusCode, RequestID: requestID, ErrorClass: "unauthorized"})
		return ErrUnauthorized
	}
	if resp.StatusCode == 403 {
		var apiErr struct {
			Code int `json:"code"`
		}
		limited, _ := io.ReadAll(io.LimitReader(resp.Body, 64<<10))
		if json.Unmarshal(limited, &apiErr) == nil && apiErr.Code == 403002039 {
			securelog.LogSecurityEvent(ctx, securelog.SecurityEvent{Operation: "api_request", Method: req.Method, Path: apiPath, Status: resp.StatusCode, RequestID: requestID, ErrorClass: "already_exists"})
			return ErrAlreadyExists
		}
		securelog.LogSecurityEvent(ctx, securelog.SecurityEvent{Operation: "api_request", Method: req.Method, Path: apiPath, Status: resp.StatusCode, RequestID: requestID, ErrorClass: "forbidden"})
		return ErrForbidden
	}
	if resp.StatusCode == 404 {
		securelog.LogSecurityEvent(ctx, securelog.SecurityEvent{Operation: "api_request", Method: req.Method, Path: apiPath, Status: resp.StatusCode, RequestID: requestID, ErrorClass: "not_found"})
		return ErrNotFound
	}
	if resp.StatusCode >= 400 {
		securelog.LogSecurityEvent(ctx, securelog.SecurityEvent{Operation: "api_request", Method: req.Method, Path: apiPath, Status: resp.StatusCode, RequestID: requestID, ErrorClass: "remote_error"})
		return fmt.Errorf("huadian: remote status %d", resp.StatusCode)
	}

	if result != nil {
		const maxJSONResp = 2 << 20 // 2 MiB
		lr := io.LimitReader(resp.Body, maxJSONResp+1)
		rawBody, err := io.ReadAll(lr)
		if err != nil {
			return fmt.Errorf("read response: %w", err)
		}
		if len(rawBody) > maxJSONResp {
			return ErrResponseTooLarge
		}
		if err := json.Unmarshal(rawBody, result); err != nil {
			return fmt.Errorf("decode: %w", err)
		}
	}
	return nil
}

// ---------------------------------------------------------------------------
// List
// ---------------------------------------------------------------------------

type dirListRequest struct {
	DocID string `json:"docid"`
	Sort  string `json:"sort,omitempty"`
	By    string `json:"by,omitempty"`
	Count int    `json:"count,omitempty"`
}

type dirListResponse struct {
	Dirs  []fileEntry `json:"dirs"`
	Files []fileEntry `json:"files"`
}

type fileEntry struct {
	DocID    string `json:"docid"`
	Name     string `json:"name"`
	Size     int64  `json:"size,omitempty"`
	Rev      string `json:"rev"`
	Modified int64  `json:"modified"` // microseconds
	Editor   string `json:"editor"`
	IsDir    bool   `json:"isdir"`
}

func (p *Provider) List(ctx context.Context, remotePath string) ([]domain.FileInfo, error) {
	rp := cleanRemote(remotePath)
	if rp == "/" {
		p.pathMu.RLock()
		rid := p.rootDocID
		p.pathMu.RUnlock()
		if rid == "" {
			return nil, fmt.Errorf("huadian List: root docid not set")
		}
		return p.listByDocID(ctx, rid, "/")
	}
	docID, err := p.resolvePath(ctx, remotePath)
	if err != nil {
		return nil, fmt.Errorf("huadian List(%q): %w", remotePath, err)
	}
	e := p.cachedEntry(rp)
	if e != nil && !e.IsDir {
		return nil, fmt.Errorf("huadian List(%q): not a directory", remotePath)
	}
	return p.listByDocID(ctx, docID, rp)
}

// listByDocID lists directory contents via the API and caches results.
// parentDir is the full remote path of the directory being listed,
// used to construct correct full-path cache keys.
func (p *Provider) listByDocID(ctx context.Context, docID string, parentDir string) ([]domain.FileInfo, error) {
	var resp dirListResponse
	req := dirListRequest{DocID: docID, Count: 100}
	if err := p.post(ctx, "/api/efast/v1/dir/list", req, &resp); err != nil {
		return nil, err
	}
	parentDir = cleanRemote(parentDir)
	var out []domain.FileInfo
	for _, e := range resp.Dirs {
		e.IsDir = true
		entryPath := parentPathJoin(parentDir, e.Name)
		out = append(out, domain.FileInfo{
			Path:    entryPath,
			Size:    e.Size,
			ModTime: time.UnixMicro(e.Modified),
			IsDir:   true,
			ETag:    e.Rev,
		})
		p.cacheDocID(entryPath, e.DocID)
		p.cacheEntry(entryPath, e)
	}
	for _, e := range resp.Files {
		entryPath := parentPathJoin(parentDir, e.Name)
		out = append(out, domain.FileInfo{
			Path:    entryPath,
			Size:    e.Size,
			ModTime: time.UnixMicro(e.Modified),
			IsDir:   false,
			ETag:    e.Rev,
		})
		p.cacheDocID(entryPath, e.DocID)
		p.cacheEntry(entryPath, e)
	}
	return out, nil
}

func parentPathJoin(parent, name string) string {
	if parent == "/" {
		return "/" + name
	}
	return parent + "/" + name
}

// ListByDocID performs a directory listing using a docid.
func (p *Provider) ListByDocID(ctx context.Context, docID string) ([]domain.FileInfo, error) {
	return p.listByDocID(ctx, docID, "/")
}

