	DocID      string `json:"docid"`
	ID         string `json:"id"`
	Name       string `json:"name"`
	IsDirExist bool   `json:"isdirexist"`
}

func (p *Provider) Copy(ctx context.Context, sourcePath, destinationDirectory string, policy cloud.TransferConflictPolicy) (cloud.TransferResult, error) {
	return p.transfer(ctx, false, sourcePath, destinationDirectory, policy)
}

func (p *Provider) Move(ctx context.Context, sourcePath, destinationDirectory string, policy cloud.TransferConflictPolicy) (cloud.TransferResult, error) {
	return p.transfer(ctx, true, sourcePath, destinationDirectory, policy)
}

func (p *Provider) transfer(ctx context.Context, move bool, sourcePath, destinationDirectory string, policy cloud.TransferConflictPolicy) (cloud.TransferResult, error) {
	sourcePath = cleanRemote(sourcePath)
	destinationDirectory = cleanRemote(destinationDirectory)
	if sourcePath == "/" {
		return cloud.TransferResult{}, ErrUnsupportedConflict
	}
	source, err := p.Stat(ctx, sourcePath)
	if err != nil {
		return cloud.TransferResult{}, err
	}
	destination, err := p.Stat(ctx, destinationDirectory)
	if err != nil {
		return cloud.TransferResult{}, err
	}
	if !destination.IsDir {
		return cloud.TransferResult{}, ErrNotDirectory
	}
	if source.IsDir && (destinationDirectory == sourcePath || strings.HasPrefix(destinationDirectory, sourcePath+"/")) {
		if move {
			return cloud.TransferResult{}, ErrInvalidMoveDescendant
		}
		return cloud.TransferResult{}, ErrInvalidCopyDescendant
	}
	if move && remoteParent(sourcePath) == destinationDirectory {
		return cloud.TransferResult{}, ErrInvalidMoveSameParent
	}
	if err := validateTransferPolicy(move, source.IsDir, policy); err != nil {
		return cloud.TransferResult{}, err
	}
	sourceID, err := p.resolvePath(ctx, sourcePath)
	if err != nil {
		return cloud.TransferResult{}, err
	}
	destinationID, err := p.resolvePath(ctx, destinationDirectory)
	if err != nil {
		return cloud.TransferResult{}, err
	}
	if docLibrary(sourceID) == "" || docLibrary(sourceID) != docLibrary(destinationID) {
		return cloud.TransferResult{}, ErrCrossLibrary
	}
	entries, err := p.List(ctx, destinationDirectory)
	if err != nil {
		return cloud.TransferResult{}, err
	}
	sourceName := path.Base(sourcePath)
	var existingPath string
	for _, entry := range entries {
		if strings.EqualFold(path.Base(entry.Path), sourceName) {
			existingPath = entry.Path
			break
		}
	}
	ondup := transferOnDup(policy)
	endpoint := "/api/efast/v1/file/copy"
	if move {
		endpoint = "/api/efast/v1/file/move"
	}
	if source.IsDir {
		endpoint = "/api/efast/v1/dir/copy"
		if move {
			endpoint = "/api/efast/v1/dir/move"
		}
	}
	var resp transferResponse
	if err := p.post(ctx, endpoint, transferRequest{DocID: sourceID, DestParent: destinationID, OnDup: ondup}, &resp); err != nil {
		return cloud.TransferResult{}, err
	}
	responseID := resp.DocID
	if responseID == "" {
		responseID = resp.ID
	}
	if responseID == "" {
		return cloud.TransferResult{}, ErrMalformedResponse
	}

	// Invalidate all paths whose identity or contents may have changed before
	// reading fresh server state. In particular, merge invalidates the entire
	// pre-existing destination subtree.
	p.invalidateCache(destinationDirectory)
	if existingPath != "" && (policy == cloud.TransferConflictOverwrite || policy == cloud.TransferConflictMerge) {
		p.invalidateCache(existingPath)
	}
	if move {
		p.invalidateCache(remoteParent(sourcePath))
		p.invalidateCache(sourcePath)
	}
	updated, err := p.List(ctx, destinationDirectory)
	if err != nil {
		return cloud.TransferResult{}, verificationError(err)
	}
	final, finalID, ok := p.entryByDocID(updated, responseID)
	if !ok {
		return cloud.TransferResult{}, ErrVerification
	}
	name := path.Base(final.Path)
	if resp.Name != "" {
		name = resp.Name
		if final.Path != parentPathJoin(destinationDirectory, name) {
			return cloud.TransferResult{}, ErrVerification
		}
	}
	finalPath := parentPathJoin(destinationDirectory, name)
	if finalID != responseID || final.IsDir != source.IsDir || (!source.IsDir && final.Size != source.Size) {
		return cloud.TransferResult{}, ErrVerification
	}
	if policy == cloud.TransferConflictOverwrite && countSameName(updated, name, false) != 1 {
		return cloud.TransferResult{}, ErrVerification
	}

	sourceEntries := updated
	if remoteParent(sourcePath) != destinationDirectory {
		p.invalidateCache(remoteParent(sourcePath))
		sourceEntries, err = p.List(ctx, remoteParent(sourcePath))
		if err != nil {
			return cloud.TransferResult{}, verificationError(err)
		}
	}
	_, _, sourceStillExists := p.entryByDocID(sourceEntries, sourceID)
	if move == sourceStillExists {
		return cloud.TransferResult{}, ErrVerification
	}
	return cloud.TransferResult{SourcePath: sourcePath, DestinationDirectory: destinationDirectory, FinalPath: finalPath, FinalName: name}, nil
}

func validateTransferPolicy(move, isDir bool, policy cloud.TransferConflictPolicy) error {
	if !move && isDir {
		if policy != cloud.TransferConflictAutoRename {
			return ErrUnsupportedDirCopyFail
		}
		return nil
	}
	if move && isDir {
		if policy != cloud.TransferConflictFail && policy != cloud.TransferConflictMerge {
			return ErrUnsupportedDirMove
		}
		return nil
	}
	if move && policy == cloud.TransferConflictMerge {
		return ErrUnsupportedFileMove
	}
	if policy != cloud.TransferConflictFail && policy != cloud.TransferConflictAutoRename && policy != cloud.TransferConflictOverwrite {
		return ErrUnsupportedConflict
	}
	return nil
}

func transferOnDup(policy cloud.TransferConflictPolicy) int {
	switch policy {
	case cloud.TransferConflictAutoRename:
		return 2
	case cloud.TransferConflictOverwrite, cloud.TransferConflictMerge:
		return 3
	default:
		return 1
	}
}

func (p *Provider) entryByDocID(entries []domain.FileInfo, docID string) (domain.FileInfo, string, bool) {
	for _, entry := range entries {
		if id, ok := p.cachedDocID(entry.Path); ok && id == docID {
			return entry, id, true
		}
	}
	return domain.FileInfo{}, "", false
}

func countSameName(entries []domain.FileInfo, name string, isDir bool) int {
	count := 0
	for _, entry := range entries {
		if entry.IsDir == isDir && strings.EqualFold(path.Base(entry.Path), name) {
			count++
		}
	}
	return count
}

func verificationError(err error) error {
	return fmt.Errorf("%w: %v", ErrVerification, err)
}

func docLibrary(docID string) string {
	trimmed := strings.TrimPrefix(docID, "gns://")
	if i := strings.IndexByte(trimmed, '/'); i > 0 {
		return trimmed[:i]
	}
	return ""
}

func remoteParent(remotePath string) string {
	parent, _ := dirAndName(remotePath)
	return parent
}

// ---------------------------------------------------------------------------
// Rename
// ---------------------------------------------------------------------------

type renameRequest struct {
	DocID string `json:"docid"`
	Name  string `json:"name"`
	OnDup int    `json:"ondup,omitempty"`
}

func (p *Provider) Rename(ctx context.Context, oldPath, newPath string) error {
	docID, err := p.resolvePath(ctx, oldPath)
	if err != nil {
		return fmt.Errorf("huadian Rename(%q): %w", oldPath, err)
	}
	_, newName := dirAndName(newPath)
	if newName == "" {
		return fmt.Errorf("huadian Rename: invalid new path %q", newPath)
	}
	if err := p.RenameByDocID(ctx, docID, newName); err != nil {
		return err
	}
	// Invalidate old path subtree and new path's parent.
	p.invalidateCache(oldPath)
	p.invalidateCache(dirAndNameStr(newPath))
	return nil
}

func dirAndNameStr(pth string) string {
	d, _ := dirAndName(pth)
	return d
}

// RenameByDocID renames a file by docid.
func (p *Provider) RenameByDocID(ctx context.Context, docID, newName string) error {
	return p.post(ctx, "/api/efast/v1/file/rename", renameRequest{
		DocID: docID,
		Name:  newName,
	}, nil)
}

// ---------------------------------------------------------------------------
// Remove
// ---------------------------------------------------------------------------

type deleteRequest struct {
	DocID string `json:"docid"`
}

func (p *Provider) Remove(ctx context.Context, remotePath string) error {
	docID, err := p.resolvePath(ctx, remotePath)
	if err != nil {
		return fmt.Errorf("huadian Remove(%q): %w", remotePath, err)
	}
	if err := p.RemoveByDocID(ctx, docID); err != nil {
		return err
	}
	// Invalidate removed path + subtree + parent.
	p.invalidateCache(remotePath)
	p.invalidateCache(dirAndNameStr(remotePath))
	return nil
}

// RemoveByDocID deletes a file or directory by docid.
func (p *Provider) RemoveByDocID(ctx context.Context, docID string) error {
	return p.post(ctx, "/api/efast/v1/file/delete", deleteRequest{
		DocID: docID,
	}, nil)
}

