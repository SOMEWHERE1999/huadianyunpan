type metadataRequest struct {
	DocID string `json:"docid"`
}

type metadataResponse struct {
	DocID    string `json:"docid"`
	Name     string `json:"name"`
	Size     int64  `json:"size,omitempty"`
	Rev      string `json:"rev"`
	Modified int64  `json:"modified"`
	IsDir    bool   `json:"isdir"`
}

func (p *Provider) Stat(ctx context.Context, remotePath string) (domain.FileInfo, error) {
	rp := cleanRemote(remotePath)

	// Root is always a directory.
	if rp == "/" {
		return domain.FileInfo{Path: "/", IsDir: true}, nil
	}

	// resolvePath walks from root, listing each level via server.
	// This populates the entry cache with full-path keys.
	_, err := p.resolvePath(ctx, remotePath)
	if err != nil {
		return domain.FileInfo{}, fmt.Errorf("huadian Stat(%q): %w", remotePath, err)
	}

	// The resolvePath walk caches each discovered segment.
	if e := p.cachedEntry(rp); e != nil {
		return domain.FileInfo{
			Path:    rp,
			Size:    e.Size,
			ModTime: time.UnixMicro(e.Modified),
			IsDir:   e.IsDir,
			ETag:    e.Rev,
		}, nil
	}

	// Fallback: call metadata API if the entry was not yielded by parent listing.
	docID, _ := p.cachedDocID(rp)
	if docID != "" {
		return p.StatByDocID(ctx, docID)
	}
	return domain.FileInfo{}, fmt.Errorf("huadian: path not found: %q", remotePath)
}

// StatByDocID returns metadata for a single file by docid.
func (p *Provider) StatByDocID(ctx context.Context, docID string) (domain.FileInfo, error) {
	var resp metadataResponse
	if err := p.post(ctx, "/api/efast/v1/file/metadata", metadataRequest{DocID: docID}, &resp); err != nil {
		return domain.FileInfo{}, err
	}
	info := domain.FileInfo{
		Path:    "/" + resp.Name,
		Size:    resp.Size,
		ModTime: time.UnixMicro(resp.Modified),
		IsDir:   resp.IsDir,
		ETag:    resp.Rev,
	}
	p.cacheDocID(info.Path, resp.DocID)
	return info, nil
}

