	ErrPartialDirectoryUpload   = errors.New("huadian: partial_directory_upload")
	ErrInvalidLocalEntry        = errors.New("huadian: invalid_local_entry")
	ErrResponseTooLarge         = errors.New("huadian: API response exceeded size limit")
)

const (
	baseURL        = "https://pan.ncepu.edu.cn"
	defaultTimeout = 30 * time.Second
)

// Provider implements cloud.Provider for Huadian AnyShare.
type Provider struct {
	baseURL     string
	accessToken string
	useToken    bool
	userID      string
	csrfToken   string
	client      *http.Client

	rootDocID  string
	pathMu     sync.RWMutex
	docidCache map[string]string    // remote path → docid
	entryCache map[string]fileEntry // remote path → cached metadata
}

// New creates a Provider.  accessToken may be empty (caller must supply
// a valid token before making API calls), in which case Connect will
// return ErrUnauthorized unless cookies are set.
func New(accessToken string) *Provider {
	return &Provider{
		baseURL:     baseURL,
		accessToken: accessToken,
		useToken:    accessToken != "",
		client: &http.Client{
			Timeout: defaultTimeout,
		},
		docidCache: make(map[string]string),
		entryCache: make(map[string]fileEntry),
	}
}

// SetUserID stores the userid for root-docid auto-discovery.
func (p *Provider) SetUserID(userID string) {
	p.userID = userID
}

// DisableTokenAuth prevents the provider from sending the Bearer
// token in API requests. Use this when authentication is handled
// exclusively by cookies (e.g., OAuth2 session cookies).
func (p *Provider) DisableTokenAuth() {
	p.useToken = false
}

// SetCSRFToken sets the CSRF token to include as X-CSRF-TOKEN header.
// The AnyShare API gateway requires this for state-changing requests.
func (p *Provider) SetCSRFToken(token string) {
	p.csrfToken = token
}

func (p *Provider) Name() string { return "huadian" }

// SetCookies injects HTTP cookies into the provider's HTTP client via a
// cookie jar. All subsequent API requests will include these cookies
// alongside the Bearer authorization header.
func (p *Provider) SetCookies(cookies []*http.Cookie) {
	if len(cookies) == 0 {
		return
	}
	jar, err := cookiejar.New(nil)
	if err != nil {
		return
	}
	u, _ := url.Parse(p.baseURL)
	jar.SetCookies(u, cookies)
	p.client.Jar = jar
}

// NewWithSession creates a provider from a stored login session.
// It constructs a cookie jar from the session cookies and uses
// the access token for Bearer authorization.
func NewWithSession(accessToken string, storedCookies []*http.Cookie) *Provider {
	p := New(accessToken)
	p.SetCookies(storedCookies)
	return p
}

// SetRootDocID sets the root directory docid for path-to-docid resolution.
func (p *Provider) SetRootDocID(docID string) {
	p.pathMu.Lock()
	defer p.pathMu.Unlock()
	p.rootDocID = docID
	p.docidCache["/"] = docID
}

// ---------------------------------------------------------------------------
// Path resolution helpers
// ---------------------------------------------------------------------------

func cleanRemote(remotePath string) string {
	s := strings.TrimSpace(remotePath)
	if s == "" || s == "/" {
		return "/"
	}
	return "/" + strings.Trim(s, "/")
}

func dirAndName(remotePath string) (parentDir, name string) {
	clean := cleanRemote(remotePath)
	if clean == "/" {
		return "/", ""
	}
	name = path.Base(clean)
	parentDir = path.Dir(clean)
	if parentDir == "." {
		parentDir = "/"
	}
	return parentDir, name
}

func (p *Provider) cachedDocID(remotePath string) (string, bool) {
	p.pathMu.RLock()
	defer p.pathMu.RUnlock()
	id, ok := p.docidCache[cleanRemote(remotePath)]
	return id, ok
}

func (p *Provider) cacheDocID(remotePath, docID string) {
	p.pathMu.Lock()
	defer p.pathMu.Unlock()
	p.docidCache[cleanRemote(remotePath)] = docID
}

func (p *Provider) cachedEntry(remotePath string) *fileEntry {
	p.pathMu.RLock()
	defer p.pathMu.RUnlock()
	e, ok := p.entryCache[cleanRemote(remotePath)]
	if !ok {
		return nil
	}
	return &e
}

func (p *Provider) cacheEntry(remotePath string, e fileEntry) {
	p.pathMu.Lock()
	defer p.pathMu.Unlock()
	p.entryCache[cleanRemote(remotePath)] = e
}

// invalidateCache removes the given path and all descendants from
// both the docid and entry caches.
func (p *Provider) invalidateCache(remotePath string) {
	p.pathMu.Lock()
	defer p.pathMu.Unlock()
	rp := cleanRemote(remotePath)
	prefix := rp + "/"
	for k := range p.docidCache {
		if k == rp || strings.HasPrefix(k, prefix) {
			delete(p.docidCache, k)
		}
	}
	for k := range p.entryCache {
		if k == rp || strings.HasPrefix(k, prefix) {
			delete(p.entryCache, k)
		}
	}
}

// resolvePath resolves a remote path to its docid and metadata by
// walking from the root directory, listing each level from the server.
// It populates the cache with full-path keys as it descends.
//
// The path parameter is interpreted relative to the root.
func (p *Provider) resolvePath(ctx context.Context, remotePath string) (string, error) {
	rp := cleanRemote(remotePath)
	if rp == "/" {
		p.pathMu.RLock()
		rootID := p.rootDocID
		p.pathMu.RUnlock()
		if rootID == "" {
			return "", fmt.Errorf("huadian: root docid not set")
		}
		return rootID, nil
	}

	// Fast path: already cached.
	if docID, ok := p.cachedDocID(rp); ok {
		return docID, nil
	}

	// Walk segments from root.
	segs := strings.Split(strings.Trim(rp, "/"), "/")
	currentDocID := ""
	{
		p.pathMu.RLock()
		currentDocID = p.rootDocID
		p.pathMu.RUnlock()
	}
	if currentDocID == "" {
		return "", fmt.Errorf("huadian: root docid not set")
	}

	builtPath := ""
	for i, seg := range segs {
		builtPath += "/" + seg
		// Check cache at this level.
		if id, ok := p.cachedDocID(builtPath); ok {
			currentDocID = id
			continue
		}

		// List current directory via server.
		entries, err := p.listByDocID(ctx, currentDocID, cleanRemote(builtPath[:strings.LastIndex(builtPath, "/")]))
		if err != nil {
			return "", fmt.Errorf("huadian: resolve %q: %w", remotePath, err)
		}
		_ = entries

		// Look up this segment in the freshly-populated cache.
		if id, ok := p.cachedDocID(builtPath); ok {
			currentDocID = id
			// Verify intermediate segment is a directory.
			e := p.cachedEntry(builtPath)
			if e != nil && !e.IsDir && i < len(segs)-1 {
				return "", fmt.Errorf("huadian: path component %q is not a directory", seg)
			}
			continue
		}
		return "", fmt.Errorf("huadian: path not found: %q", remotePath)
	}
	return currentDocID, nil
}

// resolveDocID returns the docid for a remote path.
func (p *Provider) resolveDocID(ctx context.Context, remotePath string) (string, error) {
	return p.resolvePath(ctx, remotePath)
}

