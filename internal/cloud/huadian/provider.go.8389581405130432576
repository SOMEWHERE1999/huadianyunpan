func (p *Provider) UploadDirectory(ctx context.Context, localDirectory, remoteParent string, policy cloud.DirectoryUploadConflictPolicy) (cloud.UploadResult, error) {
	rootInfo, err := os.Lstat(localDirectory)
	if err != nil {
		return cloud.UploadResult{}, fmt.Errorf("stat local directory: %w", err)
	}
	if !rootInfo.IsDir() || rootInfo.Mode()&os.ModeSymlink != 0 {
		return cloud.UploadResult{}, ErrInvalidLocalEntry
	}
	if policy != cloud.DirectoryConflictFail {
		return cloud.UploadResult{}, ErrUnsupportedDirUpload
	}
	parentInfo, err := p.Stat(ctx, remoteParent)
	if err != nil {
		return cloud.UploadResult{}, err
	}
	if !parentInfo.IsDir {
		return cloud.UploadResult{}, ErrNotDirectory
	}
	parentID, err := p.resolvePath(ctx, remoteParent)
	if err != nil {
		return cloud.UploadResult{}, err
	}
	rootName := filepath.Base(filepath.Clean(localDirectory))
	ondup := 1
	created, err := p.createDirectory(ctx, parentID, rootName, ondup)
	if err != nil {
		return cloud.UploadResult{}, err
	}
	remoteRoot := parentPathJoin(cleanRemote(remoteParent), created.Name)
	p.cacheDocID(remoteRoot, created.DocID)
	p.cacheEntry(remoteRoot, fileEntry{DocID: created.DocID, Name: created.Name, IsDir: true})
	if err := p.uploadDirectoryChildren(ctx, filepath.Clean(localDirectory), filepath.Clean(localDirectory), created.DocID, remoteRoot); err != nil {
		return cloud.UploadResult{}, fmt.Errorf("%w: %v", ErrPartialDirectoryUpload, err)
	}
	p.invalidateCache(remoteParent)
	return cloud.UploadResult{RequestedPath: parentPathJoin(cleanRemote(remoteParent), filepath.Base(filepath.Clean(localDirectory))), FinalPath: remoteRoot, FinalName: created.Name}, nil
}

func (p *Provider) uploadDirectoryChildren(ctx context.Context, root, localDir, parentID, remoteDir string) error {
	entries, err := os.ReadDir(localDir)
	if err != nil {
		return err
	}
	sort.Slice(entries, func(i, j int) bool { return entries[i].Name() < entries[j].Name() })
	for _, entry := range entries {
		localPath := filepath.Join(localDir, entry.Name())
		rel, relErr := filepath.Rel(root, localPath)
		if relErr != nil || rel == ".." || strings.HasPrefix(rel, ".."+string(filepath.Separator)) {
			return fmt.Errorf("%s: %w", filepath.ToSlash(rel), ErrInvalidLocalEntry)
		}
		info, err := os.Lstat(localPath)
		if err != nil {
			return fmt.Errorf("%s: %w", filepath.ToSlash(rel), err)
		}
		if info.Mode()&os.ModeSymlink != 0 || (!info.Mode().IsRegular() && !info.IsDir()) {
			return fmt.Errorf("%s: %w", filepath.ToSlash(rel), ErrInvalidLocalEntry)
		}
		if info.IsDir() {
			created, err := p.createDirectory(ctx, parentID, entry.Name(), 1)
			if err != nil {
				return fmt.Errorf("%s: %w", filepath.ToSlash(rel), err)
			}
			childRemote := parentPathJoin(remoteDir, created.Name)
			p.cacheDocID(childRemote, created.DocID)
			p.cacheEntry(childRemote, fileEntry{DocID: created.DocID, Name: created.Name, IsDir: true})
			if err := p.uploadDirectoryChildren(ctx, root, localPath, created.DocID, childRemote); err != nil {
				return err
			}
			continue
		}
		file, err := os.Open(localPath)
		if err != nil {
			return fmt.Errorf("%s: %w", filepath.ToSlash(rel), err)
		}
		done, err := p.uploadSeekable(ctx, parentID, entry.Name(), file, info.Size(), info.ModTime(), cloud.UploadConflictFail)
		closeErr := file.Close()
		if err != nil {
			return fmt.Errorf("%s: %w", filepath.ToSlash(rel), err)
		}
		if closeErr != nil {
			return fmt.Errorf("%s: %w", filepath.ToSlash(rel), closeErr)
		}
		finalName := done.Name
		if finalName == "" {
			finalName = entry.Name()
		}
		p.invalidateCache(remoteDir)
		p.cacheDocID(remoteDir, parentID)
		if _, err := p.verifyUploadedFile(ctx, remoteDir, entry.Name(), finalName, info.Size(), done.Rev, cloud.UploadConflictFail); err != nil {
			return fmt.Errorf("%s: %w", filepath.ToSlash(rel), err)
		}
	}
	return nil
}

