func (p *Provider) Connect(_ context.Context) error {
	if p.accessToken == "" && (p.client.Jar == nil) {
		return ErrInteractiveLoginRequired
	}
	return nil
}

func (p *Provider) UploadFile(ctx context.Context, localPath, remotePath string, policy cloud.UploadConflictPolicy) (cloud.UploadResult, error) {
	info, err := os.Lstat(localPath)
	if err != nil {
		return cloud.UploadResult{}, fmt.Errorf("stat local file: %w", err)
	}
	if !info.Mode().IsRegular() {
		return cloud.UploadResult{}, ErrInvalidLocalEntry
	}
	file, err := os.Open(localPath)
	if err != nil {
		return cloud.UploadResult{}, fmt.Errorf("open local file: %w", err)
	}
	defer file.Close()
	parent, requestedName := dirAndName(remotePath)
	if requestedName == "" {
		return cloud.UploadResult{}, ErrSourceIsDirectory
	}
	parentID, err := p.resolvePath(ctx, parent)
	if err != nil {
		return cloud.UploadResult{}, err
	}
	name := requestedName
	if policy == cloud.UploadConflictAutoRename {
		name, err = p.suggestName(ctx, "/api/efast/v1/file/getsuggestname", parentID, name)
		if err != nil {
			return cloud.UploadResult{}, err
		}
	}
	done, err := p.uploadSeekable(ctx, parentID, name, file, info.Size(), info.ModTime(), policy)
	if err != nil {
		return cloud.UploadResult{}, err
	}
	finalName := done.Name
	if finalName == "" {
		finalName = name
	}
	p.invalidateCache(parent)
	verified, err := p.verifyUploadedFile(ctx, parent, requestedName, finalName, info.Size(), done.Rev, policy)
	if err != nil {
		return cloud.UploadResult{}, err
	}
	return cloud.UploadResult{RequestedPath: cleanRemote(remotePath), FinalPath: verified.Path, FinalName: path.Base(verified.Path), Size: verified.Size, Revision: verified.ETag, Updated: policy == cloud.UploadConflictOverwrite}, nil
}

func (p *Provider) uploadByDocID(ctx context.Context, parentDocID, name string, data []byte, mtime time.Time, policy cloud.UploadConflictPolicy) (uploadResponse, error) {
	return p.uploadSeekable(ctx, parentDocID, name, bytes.NewReader(data), int64(len(data)), mtime, policy)
}

func (p *Provider) uploadSeekable(ctx context.Context, parentDocID, name string, content io.ReadSeeker, size int64, mtime time.Time, policy cloud.UploadConflictPolicy) (uploadResponse, error) {
	ondup := 1
	if policy == cloud.UploadConflictOverwrite {
		ondup = 3
	}
	if policy != cloud.UploadConflictFail && policy != cloud.UploadConflictAutoRename && policy != cloud.UploadConflictOverwrite {
		return uploadResponse{}, ErrUnsupportedConflict
	}
	md5Hash := md5.New()
	crcHash := crc32.NewIEEE()
	written, err := io.Copy(io.MultiWriter(md5Hash, crcHash), content)
	if err != nil {
		return uploadResponse{}, fmt.Errorf("read upload: %w", err)
	}
	if written != size {
		return uploadResponse{}, fmt.Errorf("size mismatch: got %d, want %d", written, size)
	}
	if _, err := content.Seek(0, io.SeekStart); err != nil {
		return uploadResponse{}, fmt.Errorf("rewind upload: %w", err)
	}
	md5Sum := fmt.Sprintf("%x", md5Hash.Sum(nil))
	var predup predupResponse
	if err := p.post(ctx, "/api/efast/v1/file/predupload", predupRequest{SliceMD5: md5Sum, Length: size}, &predup); err != nil {
		return uploadResponse{}, fmt.Errorf("predupload: %w", err)
	}
	clientTime := mtime.UnixMicro()
	if predup.Match {
		var done uploadResponse
		err := p.post(ctx, "/api/efast/v1/file/dupload", directUploadRequest{DocID: parentDocID, Name: name, Length: size, MD5: md5Sum, CRC32: fmt.Sprintf("%d", crcHash.Sum32()), ClientTime: clientTime, OnDup: ondup, CSFLevel: 0}, &done)
		if err != nil {
			return uploadResponse{}, fmt.Errorf("dupload: %w", err)
		}
		if done.DocID == "" {
			return uploadResponse{}, ErrMalformedResponse
		}
		return done, nil
	}
	var begin osBeginUploadResponse
	if err := p.post(ctx, "/api/efast/v1/file/osbeginupload", osBeginUploadRequest{UseHTTPS: true, ReqMethod: "POST", Name: name, DocID: parentDocID, OnDup: ondup, Length: size, ClientTime: clientTime}, &begin); err != nil {
		return uploadResponse{}, fmt.Errorf("osbeginupload: %w", err)
	}
	if begin.DocID == "" || begin.Rev == "" || len(begin.AuthRequest) == 0 {
		return uploadResponse{}, ErrMalformedResponse
	}
	ar, err := parseUploadAuthRequest(begin.AuthRequest)
	if err != nil {
		return uploadResponse{}, fmt.Errorf("%w: %v", ErrMalformedResponse, err)
	}
	if err := p.uploadToStorage(ctx, ar, content, size, name); err != nil {
		return uploadResponse{}, fmt.Errorf("%w: %v", ErrStorageUpload, err)
	}
	if err := p.post(ctx, "/api/efast/v1/file/osendupload", osEndUploadRequest{DocID: begin.DocID, Rev: begin.Rev, CSFLevel: 0}, nil); err != nil {
		return uploadResponse{}, fmt.Errorf("%w: %v", ErrUploadFinalize, err)
	}
	return uploadResponse{DocID: begin.DocID, Rev: begin.Rev, Name: begin.Name}, nil
}

func (p *Provider) suggestName(ctx context.Context, endpoint, parentID, name string) (string, error) {
	var resp suggestNameResponse
	if err := p.post(ctx, endpoint, map[string]string{"docid": parentID, "name": name}, &resp); err != nil {
		return "", fmt.Errorf("%w: %v", ErrSuggestName, err)
	}
	if strings.TrimSpace(resp.Name) == "" {
		return "", ErrSuggestName
	}
	return resp.Name, nil
}

func (p *Provider) verifyUploadedFile(ctx context.Context, parent, requested, expected string, size int64, rev string, policy cloud.UploadConflictPolicy) (domain.FileInfo, error) {
	entries, err := p.List(ctx, parent)
	if err != nil {
		return domain.FileInfo{}, fmt.Errorf("%w: %v", ErrVerification, err)
	}
	var matches []domain.FileInfo
	for _, entry := range entries {
		if !entry.IsDir && strings.EqualFold(path.Base(entry.Path), expected) {
			matches = append(matches, entry)
		}
	}
	if len(matches) != 1 || matches[0].Size != size || (rev != "" && matches[0].ETag != "" && matches[0].ETag != rev) {
		return domain.FileInfo{}, ErrVerification
	}
	if policy == cloud.UploadConflictOverwrite {
		count := 0
		for _, entry := range entries {
			if !entry.IsDir && strings.EqualFold(path.Base(entry.Path), requested) {
				count++
			}
		}
		if count != 1 {
			return domain.FileInfo{}, ErrVerification
		}
	}
	return matches[0], nil
}

func (p *Provider) Disconnect(_ context.Context) error { return nil }

func (p *Provider) Login(ctx context.Context) error {
	return ErrInteractiveLoginRequired
}

