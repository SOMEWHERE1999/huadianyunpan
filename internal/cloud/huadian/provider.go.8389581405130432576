var _ cloud.Provider = (*Provider)(nil)
var _ cloud.DirectRemoteProvider = (*Provider)(nil)

// Sentinel errors.
var (
	ErrNotImplemented           = errors.New("huadian: not implemented")
	ErrInteractiveLoginRequired = errors.New("huadian: interactive login required; obtain tokens via browser")
	ErrUnauthorized             = errors.New("huadian: unauthorized")
	ErrForbidden                = errors.New("huadian: forbidden")
	ErrNotFound                 = errors.New("huadian: not found")
	ErrAlreadyExists            = errors.New("huadian: already_exists")
	ErrNotDirectory             = errors.New("huadian: not_directory")
	ErrSourceIsDirectory        = errors.New("huadian: source_is_directory")
	ErrInvalidMoveSameParent    = errors.New("huadian: invalid_move_same_parent; use remote rename to change a name")
	ErrInvalidMoveDescendant    = errors.New("huadian: invalid_move_into_descendant")
	ErrInvalidCopyDescendant    = errors.New("huadian: invalid_copy_into_descendant")
	ErrCrossLibrary             = errors.New("huadian: cross_doc_library_unsupported")
	ErrUnsupportedConflict      = errors.New("huadian: unsupported_conflict_policy")
	ErrUnsupportedDirUpload     = errors.New("huadian: unsupported_conflict_policy_for_directory_upload")
	ErrUnsupportedDirCopyFail   = errors.New("huadian: unsupported_conflict_policy_for_directory_copy")
	ErrUnsupportedDirMove       = errors.New("huadian: unsupported_conflict_policy_for_directory_move")
	ErrUnsupportedFileMove      = errors.New("huadian: unsupported_conflict_policy_for_file_move")
	ErrMalformedResponse        = errors.New("huadian: malformed_response")
	ErrSuggestName              = errors.New("huadian: suggest_name_failed")
	ErrStorageUpload            = errors.New("huadian: object_storage_upload_failed")
	ErrUploadFinalize           = errors.New("huadian: upload_finalize_failed")
