package mock

import (
	"bytes"
	"context"
	"io"
	"testing"
)

func TestMockProvider_CRUD(t *testing.T) {
	ctx := context.Background()
	prov := New()

	// Upload
	data := []byte("hello world")
	err := prov.Upload(ctx, "/dir/file.txt", bytes.NewReader(data), int64(len(data)))
	if err != nil {
		t.Fatalf("upload failed: %v", err)
	}

	// List
	entries, err := prov.ListFiles(ctx, "/dir")
	if err != nil {
		t.Fatalf("list failed: %v", err)
	}
	if len(entries) != 1 {
		t.Fatalf("expected 1 entry, got %d", len(entries))
	}
	if entries[0].Path != "/dir/file.txt" {
		t.Errorf("path = %q", entries[0].Path)
	}
	if entries[0].Size != int64(len(data)) {
		t.Errorf("size = %d, want %d", entries[0].Size, len(data))
	}

	// Download
	var buf bytes.Buffer
	err = prov.Download(ctx, "/dir/file.txt", &buf)
	if err != nil {
		t.Fatalf("download failed: %v", err)
	}
	if !bytes.Equal(buf.Bytes(), data) {
		t.Errorf("downloaded data = %q, want %q", buf.Bytes(), data)
	}

	// Move
	err = prov.Move(ctx, "/dir/file.txt", "/dir/renamed.txt")
	if err != nil {
		t.Fatalf("move failed: %v", err)
	}

	// Verify old path gone
	_, err = prov.ListFiles(ctx, "/dir/file.txt")
	// ListFiles returns empty for non-existent prefix, not an error, so check count
	entries, _ = prov.ListFiles(ctx, "/dir")
	for _, e := range entries {
		if e.Path == "/dir/file.txt" {
			t.Error("old path still exists after move")
		}
	}

	// Delete
	err = prov.Delete(ctx, "/dir/renamed.txt")
	if err != nil {
		t.Fatalf("delete failed: %v", err)
	}

	entries, _ = prov.ListFiles(ctx, "/dir")
	if len(entries) != 0 {
		t.Errorf("expected 0 entries after delete, got %d", len(entries))
	}
}

func TestMockProvider_NotFound(t *testing.T) {
	ctx := context.Background()
	prov := New()

	err := prov.Download(ctx, "/nonexistent", io.Discard)
	if err == nil {
		t.Error("expected error for missing file")
	}

	err = prov.Delete(ctx, "/nonexistent")
	if err == nil {
		t.Error("expected error for deleting missing file")
	}
}

func TestMockProvider_Name(t *testing.T) {
	prov := New()
	if name := prov.Name(); name != "mock" {
		t.Errorf("name = %q, want %q", name, "mock")
	}
}

func TestMockProvider_UploadOverwrite(t *testing.T) {
	ctx := context.Background()
	prov := New()

	prov.Upload(ctx, "/a.txt", bytes.NewReader([]byte("first")), 5)
	prov.Upload(ctx, "/a.txt", bytes.NewReader([]byte("second")), 6)

	var buf bytes.Buffer
	prov.Download(ctx, "/a.txt", &buf)
	if string(buf.Bytes()) != "second" {
		t.Errorf("overwritten data = %q, want %q", buf.Bytes(), "second")
	}
}

func TestMockProvider_ListEmpty(t *testing.T) {
	ctx := context.Background()
	prov := New()

	entries, err := prov.ListFiles(ctx, "/")
	if err != nil {
		t.Fatalf("list failed: %v", err)
	}
