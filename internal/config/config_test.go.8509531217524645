package config

import (
	"encoding/json"
	"os"
	"path/filepath"
	"testing"
)

func TestDefault(t *testing.T) {
	cfg := Default()
	if cfg.LogLevel != "info" {
		t.Errorf("default log level = %q, want %q", cfg.LogLevel, "info")
	}
	if cfg.WorkerPoolSize != 4 {
		t.Errorf("default worker pool = %d, want %d", cfg.WorkerPoolSize, 4)
	}
}

func TestLoad_NotExist(t *testing.T) {
	cfg, err := Load(filepath.Join(t.TempDir(), "nonexistent.json"))
	if err != nil {
		t.Fatalf("unexpected error: %v", err)
	}
	if cfg.LogLevel != "info" {
		t.Errorf("expected default log level, got %q", cfg.LogLevel)
	}
}

func TestSaveAndLoad(t *testing.T) {
	dir := t.TempDir()
	path := filepath.Join(dir, "config.json")

	cfg := Default()
	cfg.LogLevel = "debug"
	cfg.WorkerPoolSize = 8
	cfg.SyncRoots = []SyncRootConfig{
		{LocalPath: "C:\\data", RemotePath: "/data"},
	}

	if err := cfg.Save(path); err != nil {
		t.Fatalf("save failed: %v", err)
	}

	loaded, err := Load(path)
	if err != nil {
		t.Fatalf("load failed: %v", err)
	}

	if loaded.LogLevel != "debug" {
		t.Errorf("log level = %q, want %q", loaded.LogLevel, "debug")
	}
	if loaded.WorkerPoolSize != 8 {
		t.Errorf("worker pool = %d, want %d", loaded.WorkerPoolSize, 8)
	}
	if len(loaded.SyncRoots) != 1 {
		t.Fatalf("expected 1 sync root, got %d", len(loaded.SyncRoots))
	}
	if loaded.SyncRoots[0].LocalPath != "C:\\data" {
		t.Errorf("local path = %q", loaded.SyncRoots[0].LocalPath)
	}
}

func TestLoad_Malformed(t *testing.T) {
	dir := t.TempDir()
	path := filepath.Join(dir, "bad.json")
	os.WriteFile(path, []byte("{not json}"), 0600)

	_, err := Load(path)
	if err == nil {
		t.Error("expected error for malformed JSON, got nil")
	}
}

func TestConfigMarshalRoundtrip(t *testing.T) {
	cfg := Default()
	cfg.LogLevel = "warn"
	cfg.SyncRoots = []SyncRootConfig{
		{LocalPath: "C:\\foo", RemotePath: "/foo"},
	}

	data, err := json.Marshal(cfg)
	if err != nil {
		t.Fatalf("marshal: %v", err)
	}

	var restored Config
	if err := json.Unmarshal(data, &restored); err != nil {
		t.Fatalf("unmarshal: %v", err)
	}
	if restored.LogLevel != "warn" {
		t.Errorf("roundtrip log level = %q", restored.LogLevel)
	}
}
