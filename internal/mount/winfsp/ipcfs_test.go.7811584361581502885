func TestNewRemoveModeUnlinkAllowed(t *testing.T) {
	var removeCalls int32
	callFn := func(req ipc.Request) (ipc.Response, error) {
		if req.Type == "fs.remove" {
			atomic.AddInt32(&removeCalls, 1)
		}
		return ipc.Response{Type: req.Type, ID: req.ID}, nil
	}
	fs := &IPCFileSystem{
		mkdirRenameMoveFileRenameMoveRemoveOnly: true,
		client:    &IPCClient{},
