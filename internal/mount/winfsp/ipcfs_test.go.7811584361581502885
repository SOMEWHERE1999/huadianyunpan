func TestMkdirOnlyMutationsRemainBlocked(t *testing.T) {
	fs := &IPCFileSystem{mkdirOnly: true}
	if rc, _ := fs.Create("/blocked.txt", fuse.O_CREAT|fuse.O_WRONLY, 0666); rc != -fuse.EROFS {
		t.Fatalf("Create=%d, want %d", rc, -fuse.EROFS)
	}
	if rc := fs.Write("/blocked.txt", []byte("x"), 0, 0); rc != -fuse.EROFS {
		t.Fatalf("Write=%d, want %d", rc, -fuse.EROFS)
	}
	if rc := fs.Rename("/a", "/b"); rc != -fuse.EROFS {
		t.Fatalf("Rename=%d, want %d", rc, -fuse.EROFS)
	}
	if rc := fs.Unlink("/a"); rc != -fuse.EROFS {
		t.Fatalf("Unlink=%d, want %d", rc, -fuse.EROFS)
	}
	if rc := fs.Rmdir("/a"); rc != -fuse.EROFS {
		t.Fatalf("Rmdir=%d, want %d", rc, -fuse.EROFS)
	}
	if rc := fs.Truncate("/a", 0, 0); rc != -fuse.EROFS {
		t.Fatalf("Truncate=%d, want %d", rc, -fuse.EROFS)
	}
	if rc := fs.Chmod("/a", 0600); rc != -fuse.EROFS {
		t.Fatalf("Chmod=%d, want %d", rc, -fuse.EROFS)
	}
	if rc := fs.Chown("/a", 1, 1); rc != -fuse.EROFS {
		t.Fatalf("Chown=%d, want %d", rc, -fuse.EROFS)
	}
	if rc := fs.Utimens("/a", nil); rc != -fuse.EROFS {
		t.Fatalf("Utimens=%d, want %d", rc, -fuse.EROFS)
	}
	if rc := fs.Setxattr("/a", "x", nil, 0); rc != -fuse.EROFS {
		t.Fatalf("Setxattr=%d, want %d", rc, -fuse.EROFS)
	}
	if rc := fs.Removexattr("/a", "x"); rc != -fuse.EROFS {
		t.Fatalf("Removexattr=%d, want %d", rc, -fuse.EROFS)
	}
}

