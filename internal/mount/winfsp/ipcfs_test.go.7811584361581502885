func TestValidateCachePath_Valid(t *testing.T) {
	dir := t.TempDir()
	fpath := filepath.Join(dir, "hello.txt")
	os.WriteFile(fpath, []byte("hello"), 0644)

	if err := validateCachePath(fpath, dir); err != nil {
		t.Errorf("valid path should pass: %v", err)
	}
}

func TestValidateCachePath_OutsideDir(t *testing.T) {
	dir := t.TempDir()
	outside := filepath.Join(t.TempDir(), "outside.txt")
	os.WriteFile(outside, []byte("hello"), 0644)

	if err := validateCachePath(outside, dir); err == nil {
		t.Error("path outside cache dir should fail")
	}
}

func TestValidateCachePath_Traversal(t *testing.T) {
	dir := t.TempDir()
	traversal, _ := filepath.Abs(filepath.Join(dir, "..", "outside.txt"))

	err := validateCachePath(traversal, dir)
	if err == nil {
		t.Error("path with .. traversal should fail")
	}
}

func TestValidateCachePath_NotRegularFile(t *testing.T) {
	dir := t.TempDir()
	subdir := filepath.Join(dir, "subdir")
	os.Mkdir(subdir, 0700)

	if err := validateCachePath(subdir, dir); err == nil {
		t.Error("directory should not pass as regular file")
	}
}

func TestValidateCachePath_NotFound(t *testing.T) {
	dir := t.TempDir()

	if err := validateCachePath(filepath.Join(dir, "nonexistent"), dir); err == nil {
		t.Error("nonexistent file should fail")
	}
}

