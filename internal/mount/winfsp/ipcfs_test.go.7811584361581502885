		callFn:    callFn,
	}

	if rc := fs.Unlink("/f.txt"); rc != 0 {
		t.Errorf("Unlink = %d, want 0", rc)
	}
	if got := removeCalls; got != 1 {
		t.Errorf("removeCalls = %d, want 1", got)
	}
}

