func TestExplicitOverwriteRequiresTruncate(t *testing.T) {
	for _, flags := range []int{os.O_WRONLY, os.O_RDWR, os.O_APPEND, os.O_CREATE | os.O_WRONLY} {
		if isExplicitOverwriteRequest(flags) {
			t.Errorf("flags %#x unexpectedly imply overwrite", flags)
		}
	}
	if !isExplicitOverwriteRequest(os.O_WRONLY | os.O_TRUNC) {
		t.Fatal("O_TRUNC did not imply overwrite")
	}
}

