func TestProjectMode(t *testing.T) {
	tests := []struct {
		name      string
		readOnly  bool
		mkdirOnly bool
		input     uint32
		want      uint32
	}{
		{"read-only directory", true, false, fuse.S_IFDIR | 0777, fuse.S_IFDIR | 0555},
		{"read-only file", true, false, fuse.S_IFREG | 0666, fuse.S_IFREG | 0444},
		{"mkdir-only directory", false, true, fuse.S_IFDIR | 0555, fuse.S_IFDIR | 0777},
		{"mkdir-only file", false, true, fuse.S_IFREG | 0666, fuse.S_IFREG | 0444},
		{"writable directory", false, false, fuse.S_IFDIR | 0555, fuse.S_IFDIR | 0755},
		{"writable file", false, false, fuse.S_IFREG | 0444, fuse.S_IFREG | 0644},
	}
	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			fs := &IPCFileSystem{readOnly: tt.readOnly, mkdirOnly: tt.mkdirOnly}
			stat := fuse.Stat_t{Mode: tt.input}
			fs.projectMode(&stat)
			if stat.Mode != tt.want {
				t.Fatalf("mode=%#o, want %#o", stat.Mode, tt.want)
			}
		})
	}
}

