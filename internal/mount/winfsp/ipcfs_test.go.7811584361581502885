	}
	rc, _ := fs.Open("/new.txt", int(os.O_WRONLY))
	if rc != 0 {
		t.Errorf("new18 Open write flags = %d, want 0", rc)
	}
}

func new18StagedTestFS(t *testing.T, exists bool) *IPCFileSystem {
