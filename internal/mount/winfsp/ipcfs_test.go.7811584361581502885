		pathLocks: make(map[string]*sync.Mutex),
		client:    &IPCClient{},
		callFn:    callFn,
		cacheDir:  t.TempDir(),
	}
}

func TestNew18CreateNewUsesFailConflictPolicy(t *testing.T) {
	fs := new18StagedTestFS(t, false)
	rc, fh := fs.Create("/new.txt", fuse.O_CREAT|fuse.O_WRONLY, 0644)
	if rc != 0 {
		t.Fatalf("Create(new) = %d, want 0", rc)
	}
	h := fs.files["/new.txt"]
	if h == nil || fh != h.fh || h.conflictPolicy != "fail" {
		t.Fatalf("staged handle = %#v, fh=%d; want conflictPolicy=fail", h, fh)
	}
}

