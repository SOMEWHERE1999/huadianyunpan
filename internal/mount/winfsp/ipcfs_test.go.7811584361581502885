func TestMkdirOnlyNeverCallsMockRemove(t *testing.T) {
	root := t.TempDir()
	provider := mock.New(root)
	var mkdirCalls atomic.Int32
	var removeCalls atomic.Int32
	callFn := func(req ipc.Request) (ipc.Response, error) {
		resp := ipc.Response{Type: req.Type, ID: req.ID}
		switch req.Type {
		case "fs.mkdir":
			var payload struct {
				Path string `json:"path"`
			}
			_ = json.Unmarshal(req.Data, &payload)
			mkdirCalls.Add(1)
			if err := provider.Mkdir(context.Background(), payload.Path); err != nil {
				resp.Error = err.Error()
			}
		case "fs.remove":
			removeCalls.Add(1)
			var payload ipc.FSRemoveRequest
			_ = json.Unmarshal(req.Data, &payload)
			if err := provider.Remove(context.Background(), payload.Path); err != nil {
				resp.Error = err.Error()
			}
		}
		return resp, nil
	}

	fs := &IPCFileSystem{
		client:    &IPCClient{},
		ctx:       context.Background(),
		files:     make(map[string]*ipcFileHandle),
		dirs:      make(map[string]*cachedDir),
		pathLocks: make(map[string]*sync.Mutex),
		mkdirOnly: true,
		callFn:    callFn,
	}
	if rc := fs.Rmdir("/kept"); rc != -fuse.EROFS {
		t.Fatalf("Rmdir=%d, want %d", rc, -fuse.EROFS)
	}
	if rc := fs.Unlink("/kept"); rc != -fuse.EROFS {
		t.Fatalf("Unlink=%d, want %d", rc, -fuse.EROFS)
	}
	if rc := fs.Mkdir("/allowed", 0770); rc != 0 {
		t.Fatalf("Mkdir=%d, want 0", rc)
	}
	if rc, _ := fs.Create("/blocked.txt", fuse.O_CREAT|fuse.O_WRONLY, 0666); rc != -fuse.EROFS {
		t.Fatalf("Create=%d, want %d", rc, -fuse.EROFS)
	}
	if got := removeCalls.Load(); got != 0 {
		t.Fatalf("mock Remove calls=%d, want 0", got)
	}
	if got := mkdirCalls.Load(); got != 1 {
		t.Fatalf("mock Mkdir calls=%d, want 1", got)
	}
	if _, err := os.Stat(filepath.Join(root, "allowed")); err != nil {
		t.Fatalf("mock directory was not created: %v", err)
	}
}

func TestReaddirIncludesDotEntriesAndIsRepeatable(t *testing.T) {
	fs := &IPCFileSystem{
		dirs:      map[string]*cachedDir{"/": {cachedAt: time.Now()}},
		mkdirOnly: true,
	}
	for i := 0; i < 20; i++ {
		var names []string
		rc := fs.Readdir("/", func(name string, _ *fuse.Stat_t, _ int64) bool {
			names = append(names, name)
			return true
		}, 0, 0)
		if rc != 0 {
			t.Fatalf("iteration %d: Readdir=%d", i, rc)
		}
		if len(names) != 2 || names[0] != "." || names[1] != ".." {
			t.Fatalf("iteration %d: names=%q", i, names)
		}
	}
}

