// Package filter provides file exclusion rules for sync operations.
package filter

import (
	"io/fs"
	"path/filepath"
	"strings"
)

// RuleType classifies a filter rule.
type RuleType int

const (
	RuleName RuleType = iota // match file base name
	RulePath                 // match path component (recursive directory)
	RuleSize                 // match by file size
)

// Rule is a single filter rule.
type Rule struct {
	Type    RuleType
	Pattern string // glob pattern for RuleName/RulePath
	MaxSize int64  // for RuleSize: exclude if size > MaxSize (0 = no limit)
}

// Filter evaluates exclusion rules against file paths.
type Filter struct {
	rules []Rule
}

// New creates a Filter with the given rules.
func New(rules []Rule) *Filter {
	return &Filter{rules: rules}
}

// DefaultExcludes returns commonly excluded patterns.
func DefaultExcludes() []Rule {
	return []Rule{
		{Type: RuleName, Pattern: "*.tmp"},
		{Type: RuleName, Pattern: "*.log"},
		{Type: RuleName, Pattern: "~$*"},
		{Type: RulePath, Pattern: ".git"},
		{Type: RulePath, Pattern: "node_modules"},
		{Type: RuleSize, MaxSize: 500 * 1024 * 1024}, // 500 MiB
	}
}

// Exclude reports whether the file at path (relative to the sync root)
// should be excluded from synchronization.
func (f *Filter) Exclude(path string, info fs.FileInfo) bool {
	base := filepath.Base(path)
	for _, r := range f.rules {
		switch r.Type {
		case RuleName:
			if match, _ := filepath.Match(r.Pattern, base); match {
				return true
			}
		case RulePath:
			if hasPathComponent(path, r.Pattern) {
				return true
			}
		case RuleSize:
			if r.MaxSize > 0 && info.Size() > r.MaxSize {
				return true
			}
		}
	}
	return false
}

// ExcludePath is like Exclude but without file info (size rules are ignored).
func (f *Filter) ExcludePath(path string) bool {
	return f.Exclude(path, nilFileInfo{})
}

type nilFileInfo struct{}

func (nilFileInfo) Name() string       { return "" }
func (nilFileInfo) Size() int64        { return 0 }
func (nilFileInfo) Mode() fs.FileMode  { return 0 }
func (nilFileInfo) ModTime() fs.FileMode { return 0 }
func (nilFileInfo) IsDir() bool        { return false }
func (nilFileInfo) Sys() any           { return nil }

// hasPathComponent returns true if any path component equals name.
// For example, hasPathComponent("a/.git/b", ".git") is true.
func hasPathComponent(path, name string) bool {
	// Normalize to forward slashes for consistent splitting.
	path = filepath.ToSlash(path)
	parts := strings.Split(path, "/")
	for _, p := range parts {
		if p == name {
			return true
		}
	}
	return false
}
